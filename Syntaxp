import pandas as pd
import numpy as np
from sklearn.feature_extraction.text import TfidfTransformer

# Baca file Excel "Processed_Output.xlsx"
data = pd.read_excel("C:/SAMUELFIX/Processed_OutputOke2.xlsx")

# Hapus kolom "label" dari data
labels = data["label"]
data = data.drop(columns=["label"])

# Inisialisasi TF-IDF Transformer
tfidf_transformer = TfidfTransformer()

# Hitung bobot TF-IDF
tfidf_matrix = tfidf_transformer.fit_transform(data)

# Hitung jumlah dokumen yang digunakan (D), dalam kasus ini jumlah baris
D = len(data)

# Inisialisasi DataFrame untuk menghitung jumlah dokumen yang mengandung term ke-i (DF_(i,d))
DF_id_df = pd.DataFrame(data=0, columns=data.columns, index=data.index)

# Menghitung jumlah dokumen yang mengandung term ke-i (DF_(i,d))
for kata in data.columns:
    DF_id_df[kata] = (data[kata] > 0).sum()

# Hitung IDF (Inverse Document Frequency)
IDF = np.log(D / (DF_id_df + 1))

# Hitung bobot TF-IDF sesuai dengan rumus yang benar
tfidf_matrix = data * IDF.values

# Ubah hasil menjadi DataFrame agar lebih mudah dibaca
tfidf_df = pd.DataFrame(data=tfidf_matrix, columns=data.columns)

# Gabungkan kolom "label" dengan hasil perhitungan TF-IDF
tfidf_df.insert(0, "label", labels)

# Simpan hasil perhitungan TF-IDF ke dalam file Excel
